{
  "id": "drm_document_text_extractor",
  "name_ko": "문서 텍스트 추출 (DRM 자동)",
  "class_name": "DrmDocumentTextExtractor",
  "asset_type": "component",
  "status": "user_testing",
  "version": "0.5.0",
  "packaging": "standalone",
  "standalone": true,
  "reusability": "shared",
  "component_scope": "general",
  "qualification": {
    "decision": "qualified_component",
    "criteria": {
      "independent_input_output": true,
      "functional_completeness": true,
      "reusable_unit": true,
      "payload_coupling": "low",
      "validation_or_error_handling": true
    },
    "review_rule": "Flow에서 사용된다는 사실만으로 Component 자격을 부여하지 않습니다."
  },
  "owner_usage": {
    "owner": "component_library",
    "usage": "여러 Flow에서 직접 조합하는 공용 최소 기능",
    "used_by_flows": [
      "drm_document_text_extraction_flow",
      "mail_attachment_summary_flow"
    ]
  },
  "source_family": "enterprise_utility_components",
  "summary_ko": "일반 문서는 로컬/DRM 경로로 처리하고 EWS JPG/JPEG는 연결된 Vision 모델로 해석하며 미지원 형식은 오류 대신 안내 텍스트로 반환합니다.",
  "source_file": "drm_document_text_extractor.py",
  "inputs": [
    {
      "type": "FileInput",
      "name": "document_files",
      "display_name": "문서 파일",
      "file_types": [
        "bmp",
        "csv",
        "doc",
        "docx",
        "hwp",
        "hwpx",
        "jpeg",
        "jpg",
        "pdf",
        "png",
        "ppt",
        "pptx",
        "rtf",
        "tif",
        "tiff",
        "txt",
        "xls",
        "xlsx",
        "7z",
        "gz",
        "rar",
        "tar",
        "zip"
      ],
      "info": "지원 문서는 로컬 또는 DRM API로 읽고 ZIP·RAR·7Z·TAR·GZ는 내용을 열지 않은 채 미지원 안내로 처리합니다.",
      "required": false,
      "is_list": true,
      "value": []
    },
    {
      "type": "DataInput",
      "name": "file_record",
      "display_name": "EWS 파일 항목",
      "info": "EWS Flow에서 file_path·file_name·source_kind가 포함된 Data 한 건을 연결합니다.",
      "required": false,
      "advanced": false
    },
    {
      "type": "HandleInput",
      "name": "vision_model",
      "display_name": "JPG 이미지 해석 모델",
      "input_types": [
        "LanguageModel"
      ],
      "required": false,
      "advanced": false,
      "info": "EWS의 JPG/JPEG 첨부를 해석할 Vision Language Model입니다. 사내 vLLM이 OpenAI 호환 멀티모달 모델을 제공하면 기본 Language Model 노드를 연결합니다."
    },
    {
      "type": "DropdownInput",
      "name": "processing_mode",
      "display_name": "처리 모드",
      "options": [
        "자동(로컬 우선)",
        "항상 DRM API",
        "DRM 미사용"
      ],
      "value": "자동(로컬 우선)",
      "info": "자동은 PDF·DOCX·PPTX·XLSX·TXT·CSV를 로컬에서 먼저 읽고 실패한 파일만 DRM API로 보냅니다. 그 밖의 형식은 DRM API로 처리합니다. 항상 DRM은 모든 파일을 API로 보내며, DRM 미사용은 DRM API 호출을 금지합니다. EWS JPG/JPEG의 Vision 모델 경로는 별도로 동작합니다.",
      "required": true
    },
    {
      "type": "MessageTextInput",
      "name": "drm_api_url",
      "display_name": "DRM API 주소",
      "info": "DRM API 호출이 필요한 모드에서 사용할 전체 주소입니다.",
      "required": false,
      "value": ""
    },
    {
      "type": "SecretStrInput",
      "name": "drm_token",
      "display_name": "DRM 토큰",
      "info": "DRM API 호출 시 Authorization: Bearer 헤더에 넣습니다. Flow JSON에는 저장하지 않습니다.",
      "required": false,
      "value": ""
    },
    {
      "type": "SecretStrInput",
      "name": "employee_no",
      "display_name": "사번",
      "info": "DRM API 호출 시 empNo로 전달합니다. 개인 식별값이므로 비밀 입력으로 처리합니다.",
      "required": false,
      "value": ""
    },
    {
      "type": "BoolInput",
      "name": "allow_insecure_http",
      "display_name": "HTTP DRM API 사용 허용",
      "info": "기본값은 꺼짐입니다. HTTPS를 지원하지 않는 폐쇄된 사내 테스트망에서만 켜세요.",
      "value": false,
      "advanced": true
    },
    {
      "type": "BoolInput",
      "name": "verify_tls",
      "display_name": "TLS 인증서 검증",
      "info": "HTTPS 인증서를 검증합니다. 사내 CA를 설치한 운영 환경에서는 켠 상태를 유지하세요.",
      "value": true,
      "advanced": true
    },
    {
      "type": "IntInput",
      "name": "timeout_seconds",
      "display_name": "제한 시간(초)",
      "info": "파일 하나의 연결·응답 읽기 timeout입니다. 1~600초 범위입니다.",
      "value": 180,
      "advanced": true
    },
    {
      "type": "IntInput",
      "name": "max_files",
      "display_name": "최대 파일 수",
      "info": "한 번 실행에서 처리할 파일 수를 1~50개로 제한합니다.",
      "value": 10,
      "advanced": true
    },
    {
      "type": "IntInput",
      "name": "max_file_size_mb",
      "display_name": "파일당 최대 크기(MB)",
      "info": "로컬 추출 또는 DRM API 업로드를 허용할 파일 하나의 최대 크기입니다.",
      "value": 50,
      "advanced": true
    },
    {
      "type": "IntInput",
      "name": "max_total_size_mb",
      "display_name": "전체 최대 크기(MB)",
      "info": "한 번 실행에서 메모리에 읽을 전체 파일의 최대 크기입니다.",
      "value": 200,
      "advanced": true
    },
    {
      "type": "IntInput",
      "name": "max_response_mb",
      "display_name": "파일당 최대 응답 크기(MB)",
      "info": "로컬 추출 텍스트와 DRM API 평문 응답을 이 크기까지만 읽습니다.",
      "value": 20,
      "advanced": true
    }
  ],
  "outputs": [
    {
      "type": "Output",
      "name": "extracted_text",
      "display_name": "추출된 문서 텍스트",
