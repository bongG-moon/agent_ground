{
  "id": "pii_confidential_data_guard",
  "name_ko": "01 PII & Confidential Data Guard",
  "class_name": "PiiConfidentialDataGuard",
  "asset_type": "component",
  "status": "user_testing",
  "version": "0.1.0",
  "standalone": true,
  "reusability": "shared",
  "source_family": "enterprise_document_rag_flow",
