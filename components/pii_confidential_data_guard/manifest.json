  "source_file": "pii_confidential_data_guard.py",
  "inputs": [
    {
      "type": "DataInput",
      "name": "documents",
      "display_name": "Documents",
      "input_types": [
        "Data",
        "JSON"
      ],
      "required": true
    },
    {
      "type": "DropdownInput",
      "name": "guard_mode",
      "display_name": "Guard Mode",
      "options": [
        "redact",
        "block"
      ],
      "value": "redact"
    },
    {
      "type": "BoolInput",
      "name": "detect_emails",
      "display_name": "Detect Email Addresses",
      "value": true,
      "advanced": true
    },
    {
      "type": "BoolInput",
      "name": "detect_phone_numbers",
      "display_name": "Detect Phone Numbers",
      "value": true,
      "advanced": true
    },
    {
      "type": "BoolInput",
      "name": "detect_national_ids",
      "display_name": "Detect National IDs",
      "value": true,
      "advanced": true
    },
    {
      "type": "BoolInput",
      "name": "detect_employee_ids",
      "display_name": "Detect Employee IDs",
      "value": true,
      "advanced": true
    },
    {
      "type": "BoolInput",
      "name": "detect_secrets",
      "display_name": "Detect Secret-like Values",
      "value": true,
      "advanced": true
    },
    {
      "type": "BoolInput",
      "name": "upgrade_classification",
      "display_name": "Upgrade Classification When Detected",
      "value": true,
      "advanced": true
    }
  ],
  "outputs": [
    {
      "type": "Output",
      "name": "safe_documents",
      "display_name": "Safe Documents",
      "method": "build_safe_documents",
      "types": [
        "Data"
      ]
    }
  ],
  "dependencies": [
    "lfx"
  ],
  "used_by_flows": [
    "enterprise_document_rag_flow"
  ],
  "risk_tags": [
    "pii_baseline",
